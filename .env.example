# Application Environment
APP_ENV=development

# Server Configuration
SERVER_ADDRESS=:8080

# Database Configuration (PostgreSQL - default)
DB_DRIVER=postgres
DB_DSN=host=localhost user=chronome password=chronome_dev dbname=chronome port=5432 sslmode=disable

# For SQLite (lightweight, no Docker required)
# DB_DRIVER=sqlite
# DB_DSN=dev.db

# Session Configuration
SESSION_SECRET=your-32-character-secret-here!!
SESSION_COOKIE_SECURE=false

# CORS Configuration
ALLOWED_ORIGIN=http://localhost:3000

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080
